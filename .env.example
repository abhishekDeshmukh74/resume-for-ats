# Required: Your Groq API key
# Get one free at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# MongoDB connection string (for pipeline run tracking)
MONGODB_URL=mongodb+srv://user:pass@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# Optional: Google Gemini API key (only needed when LLM_PROVIDER=gemini)
# Get one free at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# LLM provider toggle: "groq" (default), "gemini", or "ollama"
LLM_PROVIDER=groq
# GEMINI_MODEL=gemini-2.0-flash
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Ollama local inference (only needed when LLM_PROVIDER=ollama)
# Requires Ollama running locally — https://ollama.com
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1
